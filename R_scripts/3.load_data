# Convert SNPs annotation
snps <- read.delim(
  "/Users/meghapatil/WES-analysis/annotation/SRR099968_snps_annotated.txt",
  sep = "\t",
  stringsAsFactors = FALSE,
  skip = 157
)

write.csv(
  snps,
  "/Users/meghapatil/WES-analysis/results/SRR099968_snps_annotated.csv",
  row.names = FALSE
)


# Convert Indels annotation
indels <- read.delim(
  "/Users/meghapatil/WES-analysis/annotation/SRR099968_indels_annotated.txt",
  sep = "\t",
  stringsAsFactors = FALSE,
  skip = 157
)

write.csv(
  indels,
  "/Users/meghapatil/WES-analysis/results/SRR099968_indels_annotated.csv",
  row.names = FALSE
)
